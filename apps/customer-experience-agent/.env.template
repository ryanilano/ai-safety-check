# CRAFT MCP Server
MCP_URL=https://your-runtime-host/mcp          # Required.
PROJECT_ID=your-project-id-here               # Required. From your Craft project settings.

# Keycloak auth — run 'uv run python scripts/get_token.py' ONCE to populate this.
# The refresh token is long-lived (days/weeks); access tokens are silently renewed.
KEYCLOAK_URL=https://your-keycloak-host       # Required. Base URL (no /realms suffix).
KEYCLOAK_REFRESH_TOKEN=                        # Required. From scripts/get_token.py.

# TheLook E-Commerce data connection — from your Craft project's data source settings.
DATASOURCE_ID=your-datasource-uuid            # Required. UUID of the datasource.
CONNECTION_NAME=your-connection-name          # Required. e.g. eval-thelook-ecommerce
SCHEMA_NAME=THELOOK_ECOMMERCE                 # Required. Schema name.
SCHEMA_FQN=connection.DATABASE.SCHEMA         # Required. 3-part FQN: datasource.database.schema

# Gemini (for engagement synthesis in Node 5)
GEMINI_API_KEY=                               # Required. Get from Google AI Studio (aistudio.google.com).

# Model overrides — defaults shown; change if Google renames preview models
GEMINI_FLASH_MODEL=gemini-3.1-flash-lite  # Optional.
GEMINI_PRO_MODEL=gemini-3-pro-preview     # Optional.
